generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  firstName               String                   @map("first_name") @db.VarChar(100)
  lastName                String                   @map("last_name") @db.VarChar(100)
  email                   String                   @unique @db.VarChar(255)
  phone                   String?                  @unique @db.VarChar(20)
  passwordHash            String?                  @map("password_hash")
  role                    Role                     @default(CANDIDATE)
  status                  UserStatus               @default(PENDING_VERIFICATION)
  isEmailVerified         Boolean                  @map("is_email_verified") @default(false)
  isTwoFactorEnabled      Boolean                  @map("is_two_factor_enabled") @default(false)
  twoFactorSecret         String?                  @map("two_factor_secret")
  lastLoginAt             DateTime?                @map("last_login_at")
  createdAt               DateTime                 @map("created_at") @default(now())
  updatedAt               DateTime                 @map("updated_at") @updatedAt
  avatarUrl               String?                  @map("avatar_url")
  githubId                String?                  @map("github_id") @unique
  googleId                String?                  @map("google_id") @unique
  linkedinId              String?                  @map("linkedin_id") @unique
  auditLogs               AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  loginAttempts           LoginAttempt[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  createdTests            Test[]
  submissions             TestSubmission[]
  testSubscriptions       TestSubscription[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash") @unique
  family    String
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @map("created_at") @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([family])
  @@index([userId])
  @@index([revoked])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash") @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @map("created_at") @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash") @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @map("created_at") @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  event     String   @db.VarChar(100)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  metadata  String?  @db.LongText
  createdAt DateTime @map("created_at") @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("audit_logs")
}

model LoginAttempt {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  email         String   @db.VarChar(255)
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  success       Boolean
  failureReason String?  @map("failure_reason") @db.VarChar(200)
  createdAt     DateTime @map("created_at") @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([email, ipAddress])
  @@index([userId])
  @@index([createdAt])
  @@map("login_attempts")
}

// Assessment Models

model Test {
  id                   String          @id @default(cuid())
  recruiterId          String          @map("recruiter_id")
  title                String          @db.VarChar(255)
  description          String?         @db.Text
  category             TestCategory
  type                 TestType
  status               TestStatus      @default(DRAFT)
  rejectionReason      String?         @map("rejection_reason") @db.Text
  durationMinutes      Int?            @map("duration_minutes")
  // -- New configuration fields ----------------------------------------------
  passingScore         Int?            @map("passing_score")
  difficultyLevel      DifficultyLevel? @map("difficulty_level")
  randomizeQuestions   Boolean         @map("randomize_questions") @default(false)
  oneQuestionPerPage   Boolean         @map("one_question_per_page") @default(false)
  negativeMarking      Boolean         @map("negative_marking") @default(false)
  allowRetake          Boolean         @map("allow_retake") @default(false)
  availableFrom        DateTime?       @map("available_from")
  availableUntil       DateTime?       @map("available_until")
  showResultsInstantly Boolean         @map("show_results_instantly") @default(true)
  // antiCheating: JSON {browserLock: bool, webcam: bool, tabSwitchDetection: bool}
  antiCheating         String?         @map("anti_cheating") @db.Text
  // -------------------------------------------------------------------------
  createdAt            DateTime        @map("created_at") @default(now())
  updatedAt            DateTime        @map("updated_at") @updatedAt
  recruiter            User            @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  questions            Question[]
  submissions          TestSubmission[]
  testSubscriptions    TestSubscription[]

  @@index([recruiterId])
  @@index([category])
  @@index([status])
  @@map("tests")
}

model Question {
  id             String           @id @default(cuid())
  testId         String           @map("test_id")
  content        String           @db.Text
  orderIndex     Int              @map("order_index") @default(0)
  points         Int              @default(1)
  questionType   QuestionType     @map("question_type") @default(MCQ_SINGLE)
  // options: JSON array [{label, value, isCorrect}] - used by MCQ_SINGLE, MCQ_MULTI, TRUE_FALSE
  options        String?          @db.LongText
  expectedOutput String?          @map("expected_output") @db.Text
  // -- Type-specific fields --------------------------------------------------
  explanation    String?          @db.Text         // Post-answer explanation
  mediaUrl       String?          @map("media_url") @db.VarChar(2048)
  codeLanguage   String?          @map("code_language") @db.VarChar(50)
  codeStarter    String?          @map("code_starter") @db.LongText
  // matchPairs: JSON [{left: string, right: string}] - MATCHING
  matchPairs     String?          @map("match_pairs") @db.LongText
  // correctOrder: JSON [string, ...] - ORDERING
  correctOrder   String?          @map("correct_order") @db.LongText
  // NUMERICAL bounds
  numericalMin   Decimal?         @map("numerical_min") @db.Decimal(12, 4)
  numericalMax   Decimal?         @map("numerical_max") @db.Decimal(12, 4)
  tolerance      Decimal?         @db.Decimal(12, 4)
  // -------------------------------------------------------------------------
  createdAt      DateTime         @map("created_at") @default(now())
  updatedAt      DateTime         @map("updated_at") @updatedAt
  test           Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers        QuestionAnswer[]

  @@index([testId])
  @@index([questionType])
  @@map("questions")
}

model TestSubmission {
  id          String           @id @default(cuid())
  testId      String           @map("test_id")
  candidateId String           @map("candidate_id")
  status      SubmissionStatus @default(IN_PROGRESS)
  startedAt   DateTime         @map("started_at") @default(now())
  submittedAt DateTime?        @map("submitted_at")
  score       Decimal?         @db.Decimal(5, 2)
  maxScore    Decimal?         @map("max_score") @db.Decimal(5, 2)
  createdAt   DateTime         @map("created_at") @default(now())
  updatedAt   DateTime         @map("updated_at") @updatedAt
  test        Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  candidate   User             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  answers     QuestionAnswer[]

  @@unique([testId, candidateId])
  @@index([candidateId])
  @@index([testId])
  @@map("test_submissions")
}

model QuestionAnswer {
  id              String         @id @default(cuid())
  submissionId    String         @map("submission_id")
  questionId      String         @map("question_id")
  answerText      String?        @map("answer_text") @db.Text
  // selectedOptions: JSON array [value, ...]
  selectedOptions String?        @map("selected_options") @db.LongText
  // fileUrl: used by FILE_UPLOAD, AUDIO_RESPONSE, VIDEO_RESPONSE
  fileUrl         String?        @map("file_url") @db.VarChar(2048)
  isCorrect       Boolean?       @map("is_correct")
  pointsAwarded   Decimal?       @map("points_awarded") @db.Decimal(5, 2)
  recruiterFeedback String?      @map("recruiter_feedback") @db.Text
  createdAt       DateTime       @map("created_at") @default(now())
  updatedAt       DateTime       @map("updated_at") @updatedAt
  submission      TestSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question        Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
  @@map("question_answers")
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  DELETED
}

// Assessment Enums

enum TestCategory {
  CODING_PROGRAMMING
  DATA_STRUCTURES_ALGORITHMS
  DEBUGGING
  SYSTEM_DESIGN
  DATABASE_SQL
  OOP
  FRAMEWORK_TECHNOLOGY
  API_DEVELOPMENT
  CLOUD_DEVOPS
  VERSION_CONTROL
  TESTING_QA
  SECURITY
  PERFORMANCE_OPTIMIZATION
  CODE_REVIEW
  PROJECT_BASED
  TECHNICAL_QUIZ
  PROBLEM_SOLVING_LOGIC
  COMMUNICATION_COLLABORATION
}

enum TestType {
  QCM
  COMPTE_RENDU
  PROBLEM_SOLVING
  OTHER
}

enum TestStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum SubscriptionStatus {
  PENDING
  APPROVED
  REJECTED
}

model TestSubscription {
  id          String             @id @default(cuid())
  testId      String             @map("test_id")
  candidateId String             @map("candidate_id")
  status      SubscriptionStatus @default(PENDING)
  createdAt   DateTime           @map("created_at") @default(now())
  updatedAt   DateTime           @map("updated_at") @updatedAt
  test        Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  candidate   User               @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([testId, candidateId])
  @@index([candidateId])
  @@index([testId])
  @@index([status])
  @@map("test_subscriptions")
}

enum QuestionType {
  MCQ_SINGLE     // Multiple Choice - Single Answer (radio)
  MCQ_MULTI      // Multiple Choice - Multiple Answers (checkboxes)
  TRUE_FALSE     // True / False
  FILL_BLANK     // Fill in the Blank
  SHORT_TEXT     // Short Text Answer
  LONG_ESSAY     // Long Essay
  CODE_EDITOR    // Code Editor (compile & run)
  FILE_UPLOAD    // File Upload (PDF, ZIP, Word, Images)
  DRAG_DROP      // Drag and Drop
  MATCHING       // Matching Questions
  ORDERING       // Ordering / Sequence Questions
  NUMERICAL      // Numerical Answer
  AUDIO_RESPONSE // Audio Response
  VIDEO_RESPONSE // Video Response
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}
