# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:@localhost:3306/recruitment_auth

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_pass_2024

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=REPLACE_WITH_32_CHAR_HEX_SECRET
COOKIE_DOMAIN=localhost

# ─── CSRF ─────────────────────────────────────────────────────────────────────
CSRF_SECRET=REPLACE_WITH_32_CHAR_HEX_SECRET_FOR_CSRF

# ─── Email ────────────────────────────────────────────────────────────────────
# Development: leave blank to auto-create an Ethereal test account
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@recruitment.local

# ─── SMS ──────────────────────────────────────────────────────────────────────
# Options: mock, twilio
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── OAuth ────────────────────────────────────────────────────────────────────
# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
